&pinctrl {
	uart00_default: uart00_default {
		group1 {
			psels = <NRF_PSEL(UART_TX, 2, 7)>;
		};

		group2 {
			psels = <NRF_PSEL(UART_RX, 2, 8)>;
		};
	};

	uart00_sleep: uart00_sleep {
		group1 {
			psels = <NRF_PSEL(UART_TX, 2, 7)>;
			low-power-enable;
		};

		group2 {
			psels = <NRF_PSEL(UART_RX, 2, 8)>;
			low-power-enable;
		};
	};

	i2c20_default: i2c20_default {
		group1 {
			psels = <NRF_PSEL(TWIM_SCL, 1, 7)>,
			       <NRF_PSEL(TWIM_SDA, 1, 8)>;
		};
	};

	i2c20_sleep: i2c20_sleep {
		group1 {
			psels = <NRF_PSEL(TWIM_SCL, 1, 7)>,
			       <NRF_PSEL(TWIM_SDA, 1, 8)>;
			low-power-enable;
		};
	};

};
